<% content_for :title, "Surveys" %>

<div class="space-y-4">
  <% if @surveys.empty? %>
    <div class="text-center py-16 bg-white border border-slate-200 rounded-lg">
      <h2 class="text-lg font-medium text-slate-900">No surveys yet</h2>
      <p class="mt-1 text-sm text-slate-500">Create your first survey to get started.</p>
      <%= link_to "New survey", new_survey_path, class: "mt-4 inline-flex items-center px-4 py-2 rounded-md bg-slate-900 text-white text-sm font-medium hover:bg-slate-700" %>
    </div>
  <% else %>
    <% @surveys.each do |survey| %>
      <article class="bg-white border border-slate-200 rounded-lg p-5">
        <div class="flex items-start justify-between gap-4">
          <h2 class="text-lg font-medium text-slate-900 flex-1"><%= survey.question %></h2>
          <%= link_to "Respond", survey_path(survey), class: "shrink-0 inline-flex items-center px-3 py-1.5 rounded-md bg-slate-900 text-white text-sm font-medium hover:bg-slate-700" %>
        </div>
        <div class="mt-4">
          <% if survey.responses_count.zero? %>
            <p class="text-sm text-slate-500">No responses yet.</p>
          <% else %>
            <%= render "results", survey: survey %>
          <% end %>
        </div>
      </article>
    <% end %>
  <% end %>
</div>